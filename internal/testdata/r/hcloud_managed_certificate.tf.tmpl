{{- /* vim: set ft=terraform: */ -}}

resource "hcloud_managed_certificate" "{{ .RName }}" {
  lifecycle {
    create_before_destroy = true
  }

  name         = "{{ .Name }}--{{ .RInt }}"
  domain_names = [{{ .DomainNames | quoteEach | join ", " }}]
  {{- if .Labels }}
  labels = {{ .Labels | toPrettyJson }}
  {{- end }}
}
